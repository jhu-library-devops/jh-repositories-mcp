    "dc.description.abstract": [
      {
        "value": "This study examines climate adaptation strategies for tidal wetlands in the Chesapeake Bay watershed. Using long-term ecological monitoring data from 2010 to 2023, we evaluate the effectiveness of managed retreat, living shorelines, and hydrological restoration in maintaining wetland ecosystem services under projected sea-level rise scenarios. Results indicate that combined approaches outperform single-strategy interventions by 40% in biomass retention and 60% in carbon sequestration capacity.",
        "language": "en_US",
        "authority": null,
        "confidence": -1,
        "place": 0
      }
